PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/hybrid_edtech

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

OTP_EXPIRY_MINUTES=5

# Rate limiting
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5

# SMTP Config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
BCC_MAIL=your_bcc_email@gmail.com

# Redis (BullMQ + Cache) — use rediss:// for TLS cloud Redis (RedisLabs/Upstash)
REDIS_URL=rediss://:<password>@<host>:<port>

# Cache TTL (seconds)
TUTOR_SEARCH_CACHE_TTL=300

# Default Admin (auto-created on first server start if no admin exists)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+1000000000
ADMIN_PASSWORD=Admin@1234

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
